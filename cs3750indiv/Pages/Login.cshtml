@page
@model cs3750indiv.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="le-auth-page">
    <div class="le-auth-card">
        <h2>Welcome back</h2>
        <p class="le-auth-subtitle">Log in to your LocalEats account.</p>

        @if (Model.WelcomeMessage != null)
        {
            <div class="alert alert-success mb-4">@Model.WelcomeMessage</div>
        }

        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger mb-4">@Model.ErrorMessage</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger mb-4"></div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="jane@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" type="password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">Log in</button>
        </form>

        <div class="le-auth-footer">
            Don't have an account? <a asp-page="/Register">Register</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
